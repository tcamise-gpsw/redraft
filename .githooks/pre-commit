#!/usr/bin/env sh
set -e

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$staged_files" ]; then
  exit 0
fi

echo "pre-commit: format staged files..."
printf '%s\n' "$staged_files" | while IFS= read -r file; do
  [ -f "$file" ] || continue
  npx --no-install prettier --write --ignore-unknown "$file"
  git add -- "$file"
done

echo "pre-commit: lint..."
npm run lint --silent

echo "pre-commit: done."
